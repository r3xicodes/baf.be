# ===== SMTP Configuration (Real Email Sending) =====
# If these are not set, the server uses Nodemailer test account (preview URLs logged to console)
# For Gmail: Use App Password (not regular password) - https://support.google.com/accounts/answer/185833
# For other providers: Check their SMTP documentation

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Example for Office 365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@company.com
# SMTP_PASS=your-password

# ===== Security Settings =====
BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-random-secure-string-in-production
NODE_ENV=development

# ===== Email Configuration =====
EMAIL_FROM="Belgian Air Force <noreply@plaaf.cn>"
ADMIN_EMAIL=admin@plaaf.cn
